# BEGIN TY's CONFIG

plugins=(
	git 	# Git aliases and functions
	z 	# Quick directory navigation
	docker	# Docker aliases and autocomplete
	fzf	# Fuzzy finder integration
	zsh-autosuggestions	# Fish-like autosuggestions
	zsh-syntax-highlighting	# Syntax highlighting of commands
)

# Export path
export ZSH="$HOME/.oh-my-zsh"
export EDITOR='nvim'

# Enable p10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
	source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Set Theme
ZSH_THEME="powerlevel10k/powerlevel10k"


# source Oh My Zsh
source $ZSH/oh-my-zsh.sh

# ALIAS
alias zshconfig="nvim $HOME/.zshrc"
alias ohmyzsh="nvim $HOME/.oh-my-zsh"
alias sources="cd $HOME/sources"
alias notes="cd $HOME/notes"

sshclean(){
    ssh-keygen -R "$2" > /dev/null 2&1
    ssh "$1@$2"
}

nfl(){
    nix flake lock --update-input "$1"
}

# Use eza instead of ls if available
if command -v eza &> /dev/null; then
	alias ls='eza --icons'
	alias ll='eza -l --icons'
	alias la='eza -la --icons'
fi

# Export fuzzy finder
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# Improve command history
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_FIND_NO_DUPS

# Enable vi mode
bindkey -v


# Source cargo environment
[ -f "$HOME/.cargo/env" ] && source "$HOME/.cargo/env"

# Fuzzy find and open in vim
vf() {
	local file
	file=$(fzf --height 40% --reverse)
	[ -n "$file" ] && nvim "$file"
}

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# Export local bin path
export PATH="$HOME/.local/bin:$PATH"
